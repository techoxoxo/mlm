# ---- Apex environment ----
# Copy to .env and fill in. Never commit the real .env.

# PostgreSQL connection string
DATABASE_URL=postgresql://mlm:mlm@localhost:5432/mlm

# Redis connection string (BullMQ queue + rate limiting + pub/sub)
REDIS_URL=redis://localhost:6379

# Session signing secret. In production this MUST be a strong, unique value
# (>= 32 chars) or the app refuses to boot. Generate one with:
#   openssl rand -base64 48
JWT_SECRET=dev_super_secret_change_me_in_production_0123456789

# Public base URL of the app (used for referral links + redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000
